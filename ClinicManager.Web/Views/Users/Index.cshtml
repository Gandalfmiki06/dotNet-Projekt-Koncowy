@model List<UserListItemViewModel>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<h2>Użytkownicy</h2>

<a asp-action="Create" class="btn btn-primary mb-3">
    Dodaj nowego użytkownika
</a>

<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Nazwa użytkownika</th>
            <th>Imię i Nazwisko</th>
            <th>Role</th>
            <th>Akcje</th>
        </tr>
    </thead>

    <tbody>
    @foreach (var user in Model)
    {
        <tr>
            <td>@user.UserName</td>
            <td>@user.FullName</td>

            <td>
                @if (user.Role.Any())
                {
                    @string.Join(", ", user.Role)
                }
                else
                {
                    <span class="text-muted">Bez Roli</span>
                }
            </td>

            <td class="text-end">
                <a asp-action="Edit" asp-route-id="@user.Id"
                   class="btn btn-sm btn-warning">
                    Edytuj
                </a>

                <a asp-action="ResetPassword" asp-route-id="@user.Id"
                    class="btn btn-sm btn-danger">
                    Resetuj hasło
                </a>

                <a asp-action="Delete" asp-route-id="@user.Id"
                   class="btn btn-sm btn-danger">
                    Usuń
                </a>
            </td>
        </tr>
    }
    </tbody>
</table>